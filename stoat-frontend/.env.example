# Optional: connect gateway WebSocket directly to Stoat (skip /ws proxy). Stoat listens at path /.
# Use a different host than the page (e.g. localhost:14702 while Vite is on 5173).
# Do NOT set this to the same public hostname as the site — same-host is handled automatically via /ws.
# VITE_WS_URL=ws://127.0.0.1:14702

# Optional: you load the dev server as https://YOURDOMAIN (tunnel/reverse proxy). Without this, Vite HMR
# tries wss://localhost:5173 and fails. Set to the public hostname (no https://).
# VITE_PUBLIC_DEV_HOST=opic.fun

# Optional: custom ICE servers for voice WebRTC.
# STUN defaults to Google's public servers when omitted.
# VITE_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
#
# TURN is strongly recommended for users behind strict NAT/firewalls.
# VITE_TURN_URLS=turn:turn.yourdomain.com:3478,turns:turn.yourdomain.com:5349
# VITE_TURN_USERNAME=your_turn_username
# VITE_TURN_CREDENTIAL=your_turn_password
