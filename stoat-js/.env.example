# HTTP API + WebSocket (same port)
PORT=14702

# MongoDB
MONGODB_URI=mongodb://127.0.0.1:27017/stoat

# Public URLs (optional; returned by GET / for clients)
APP_URL=http://localhost:5173
WS_URL=ws://localhost:14702

# Rich presence: token in User Settings → PATCH /public/v1/presence. ttl_seconds lease + heartbeat; optional
# activity.image (https URL or /attachments upload). Active lease shows you online without a browser tab.

# Official in-app bot "Claw" (auto-created on API start). Override only if migrating user ids.
# OFFICIAL_CLAW_USER_ID=stoat_official_claw

# Global badge "opic_staff" is auto-created for Admin → Staff (gold STAFF tag in clients).

# CORS: comma-separated origins, or leave unset for permissive dev (origin: true)
# Example: CORS_ORIGINS=http://localhost:5173,https://app.example.com
# CORS_ORIGINS=

# Web push (optional; required to send browser push notifications)
# Generate keys: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# Message translation provider (optional, LibreTranslate-compatible)
# TRANSLATE_PROVIDER_URL=https://translate.argosopentech.com/translate
# TRANSLATE_PROVIDER_API_KEY=

# Attachments: local disk (default) or S3-compatible storage
# UPLOADS_STORAGE=local
# UPLOADS_DIR=uploads

# Optional S3 (when UPLOADS_STORAGE=s3)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=
# S3_PUBLIC_BASE_URL=https://bucket.s3.region.amazonaws.com

# Node
# NODE_ENV=development

# Env vars are loaded from this file via dotenv (see config.js). Restart the API after changes.
